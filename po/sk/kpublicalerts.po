#: app/caputil.cpp:50
msgid "Extreme — Extraordinary threat to life or property"
msgstr "Extrémna — Mimoriadna hrozba pre život alebo majetok"

#: app/caputil.cpp:51
msgid "Severe — Significant threat to life or property"
msgstr "Závažná — Významná hrozba pre život alebo majetok"

#: app/caputil.cpp:52
msgid "Moderate — Possible threat to life or property"
msgstr "Stredná — Možná hrozba pre život alebo majetok"

#: app/caputil.cpp:53
msgid "Minor — Minimal to no known threat to life or property"
msgstr "Menšia — Minimálna alebo žiadna známa hrozba pre život alebo majetok"

#: app/caputil.cpp:57
msgid "Responsive action should be taken immediately"
msgstr "Okamžite by sa mali vykonať opatrenia"

#: app/caputil.cpp:58
msgid "Responsive action should be taken soon"
msgstr "Opatrenia by sa mali vykonať čoskoro"

#: app/caputil.cpp:59
msgid "Responsive action be taken in the near future"
msgstr "Opatrenia by sa mali vykonať v blízkej budúcnosti"

#: app/caputil.cpp:60
msgid "Responsive action is no longer required"
msgstr "Opatrenia už nie sú potrebné"

#: app/caputil.cpp:64
msgid "Occurred or ongoing"
msgstr "Nastalo alebo prebieha"

#: app/caputil.cpp:65
msgid "Likely (> 50%)"
msgstr "Pravdepodobné (> 50 %)"

#: app/caputil.cpp:66
msgid "Possible but not likely (< 50%)"
msgstr "Možné, ale nepravdepodobné (< 50 %)"

#: app/caputil.cpp:67
msgid "Not expected to occur"
msgstr "Neočakáva sa"

#: app/caputil.cpp:71
msgid "Geophysical"
msgstr "Geofyzikálne"

#: app/caputil.cpp:72
msgid "Meteorological"
msgstr "Meteorologické"

#: app/caputil.cpp:73
msgid "General emergency and public safety"
msgstr "Všeobecné núdzové situácie a verejná bezpečnosť"

#: app/caputil.cpp:74
msgid "Law enforcement, military, homeland and local/private security"
msgstr ""
"Orgány činné v trestnom konaní, armáda, vnútorná a miestna/súkromná "
"bezpečnosť"

#: app/caputil.cpp:75
msgid "Rescue and recovery"
msgstr "Záchranné a obnovovacie práce"

#: app/caputil.cpp:76
msgid "Fire"
msgstr "Požiar"

#: app/caputil.cpp:77
msgid "Medical and public health"
msgstr "Zdravotníctvo a verejné zdravie"

#: app/caputil.cpp:78
msgid "Pollution and other environmental event"
msgstr "Znečistenie a iné environmentálne udalosti"

#: app/caputil.cpp:79
msgid "Transportation"
msgstr "Doprava"

#: app/caputil.cpp:80
msgid "Utility, telecommunication, other non-transport infrastructure"
msgstr "Služby, telekomunikácie, iná nedopravná infraštruktúra"

#: app/caputil.cpp:81
msgid ""
"Chemical, biological, radiological, nuclear or high-yield explosive threat "
"or attack"
msgstr ""
"Chemická, biologická, radiologická, jadrová hrozba alebo útok s vysokým "
"výbušným účinkom"

#: app/caputil.cpp:82
msgid "Other event"
msgstr "Iná udalosť"

#: app/caputil.cpp:86
msgid "Take shelter in place or per instructions."
msgstr "Ukryte sa na mieste alebo podľa pokynov."

#: app/caputil.cpp:87
msgid "Relocate as instructed."
msgstr "Presídlite sa podľa pokynov."

#: app/caputil.cpp:88
msgid "Make preparations as per the instructions."
msgstr "Vykonajte prípravy podľa pokynov."

#: app/caputil.cpp:89
msgid "Execute activities identified in the instructions."
msgstr "Vykonajte činnosti uvedené v pokynoch."

#: app/caputil.cpp:90
msgid "Avoid the subject event as per the instructions."
msgstr "Vyhnite sa predmetnému javu podľa pokynov."

#: app/caputil.cpp:91
msgid "Attend to information sources as described in the instructions."
msgstr "Venujte pozornosť informačným zdrojom popísaným v pokynoch."

#: app/caputil.cpp:92
msgid "Evaluate the information in this message."
msgstr "Vyhodnoťte informácie v tejto správe."

#: app/caputil.cpp:93
msgid ""
"The subject event no longer poses a threat or concern and any follow on "
"action is described in the instructions."
msgstr ""
"Predmetný jav už nepredstavuje hrozbu ani obavy a akékoľvek následné "
"opatrenia sú opísané v pokynoch."

#: app/caputil.cpp:94
msgid "No action recommended."
msgstr "Žiadne opatrenia sa neodporúčajú."

